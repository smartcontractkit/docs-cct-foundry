# Dependencies
node_modules/
pnpm-lock.yaml

# Foundry
cache/
out/
broadcast/
lib/

# Docs: all authored documentation under docs/ is tracked. Ignore only `forge doc` generated output.
docs/src/
docs/book/
docs/book.toml

# Safe Transaction Builder batches (run artifacts, kept local); keep the example
batches/*
!batches/example.transfer-ownership.11155111.json

# Dotenv file
.env

# MacOS system files
.DS_Store
*/.DS_Store

# Deploy history ledger (append-only, written by the deploy scripts, kept local; per-artifact
# timestamped files under history/<category>/<selectorName>/) - never tracked
history/

# Project state store (lanes + roles + deployed addresses). In THIS template repo it holds OUR
# throwaway test-deployment addresses, so it is gitignored and only the example ships. A downstream
# FORK should UN-gitignore project/ so its lanes/roles/addresses become one reviewed, git-versioned,
# team-shared source of truth (see docs/deployed-addresses.md).
project/*.json
!project/ethereum-testnet-sepolia.example.json
project/zz-scratch-*.json
project/local-*.json
# Token-group subdirectories (project/<group>/<selectorName>.json) - same policy as the flat files
project/*/*.json

# Scratch files written (and removed) by tests - never commit a leak
config/chains/zz-scratch-*.json
history/**/zz-scratch-*
project/zz-scratch-*/
# Visible test group dirs (zz-tt-*): NOT skipped by the group-sweeping tools, so tests can assert
# discovery/notice on them; still gitignored + removed by the test cleanup.
project/zz-tt-*/
