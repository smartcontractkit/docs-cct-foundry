# ==============================================================
# .env — load once per terminal session with: source .env
# ==============================================================


# --------------------------------------------------------------
# Keystore
# Created via: cast wallet import your_keystore_name --interactive
# --------------------------------------------------------------
KEYSTORE_NAME=


# --------------------------------------------------------------
# RPC URLs — fill in only the networks you plan to use
# --------------------------------------------------------------
ETHEREUM_SEPOLIA_RPC_URL=
MANTLE_SEPOLIA_RPC_URL=
# AVALANCHE_FUJI_RPC_URL=
# ARBITRUM_SEPOLIA_RPC_URL=
# BASE_SEPOLIA_RPC_URL=
# POLYGON_AMOY_RPC_URL=
# INK_SEPOLIA_RPC_URL=
# PLUME_TESTNET_RPC_URL=
# ZERO_G_TESTNET_RPC_URL=


# --------------------------------------------------------------
# Block explorer API key
# Required only when passing --verify to deployment scripts.
# Etherscan API v2 supports all chains with a single key.
# --------------------------------------------------------------
ETHERSCAN_API_KEY=


# --------------------------------------------------------------
# Optional — chain-config tooling (script/config/*)
# Non-secret override of the CCIP REST API base URL used by the
# add-chain / sync / drift-check tooling. Leave unset to use the
# public API (https://api.ccip.chain.link/v2).
# --------------------------------------------------------------
# CCIP_API_BASE=https://api.ccip.chain.link/v2
